---
import { fetchAllProducts } from "../../use-cases/queries/all-products";
import { fetchProduct } from "../../use-cases/queries/product";

import Layout from "../../layouts/Layout.astro";
import { Product as CrystallizeProduct } from "../../components/product";

export const prerender = true;

export async function getStaticPaths() {
  try {
    const paths = await fetchAllProducts();
    if (!paths?.catalogue?.children) return [];
    return paths.catalogue.children.map((child: { path: string }) => ({
      params: { product: child.path.replace("/shop/", "") },
    }));
  } catch (e) {
    return []; // Pengaman jika API Crystallize gagal dihubungi saat build
  }
}

const { product } = Astro.params;

let productData = null;
try {
  productData = await fetchProduct(`/shop/${product}`);
} catch (e) {
  productData = null;
}

// Amankan nama produk agar tidak eror jika data null
const productName = productData?.product?.name || "Product";
---

<Layout title={productName} description={productName}>
  <div class="lg:container mx-auto w-full lg:px-0 px-5">
    {
      productData?.product ? (
        /* Menggunakan client:only="react" agar react-dom-server tidak mengeksekusinya di Cloudflare saat build */
        <CrystallizeProduct product={productData.product} client:only="react" />
      ) : (
        <p class="py-10 text-center">Product not found</p>
      )
    }
  </div>
</Layout>